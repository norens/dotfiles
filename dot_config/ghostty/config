auto-update = off
theme = "TokyoNight Storm"
font-family = "JetBrainsMono Nerd Font Mono"
font-size = 16
font-thicken = true
font-thicken-strength = 128

cursor-style = block
cursor-style-blink = false

window-colorspace = display-p3
window-inherit-font-size = false
background-opacity = 1
background-blur = true

macos-titlebar-style = hidden
macos-non-native-fullscreen = true
window-save-state = always
window-padding-color = extend
window-step-resize = false
window-padding-y = 0
window-padding-balance = true
resize-overlay = never

# Cursor shaders (disable if performance issues on Intel GPU)
custom-shader = shaders/cursor_blaze_no_trail.glsl
custom-shader = shaders/cursor_smear_fade.glsl

keybind = global:cmd+shift+ctrl+t=toggle_quick_terminal
keybind = cmd+r=set_font_size:30
keybind = cmd+e=reset_font_size
keybind = cmd+enter=toggle_fullscreen
keybind = shift+enter=text:\x1b\r
