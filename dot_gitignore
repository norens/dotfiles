# Ignore everything by default
*

# Repo meta
!.gitignore
!CLAUDE.md

# Scripts
!scripts
!scripts/*

# Shell
!.zshrc
!.zsh_aliases
!.tmux.conf

# Git config
!.gitconfig

# Config files (allowlist pattern: block .config/*, then un-ignore specific items)
!.config
.config/*

# AeroSpace
!.config/aerospace
!.config/aerospace/*

# Ghostty
!.config/ghostty
!.config/ghostty/config
!.config/ghostty/shaders
!.config/ghostty/shaders/*

# Karabiner + Goku
!.config/karabiner
!.config/karabiner/karabiner.json
!.config/goku
!.config/goku/*

# SketchyBar
!.config/sketchybar
!.config/sketchybar/**

# Starship
!.config/starship.toml

# Lazygit
!.config/lazygit
!.config/lazygit/*

# Brew
!.config/brewfile
!.config/brewfile/*

# GitHub CLI (config only, NOT hosts.yml which contains auth)
!.config/gh
.config/gh/*
!.config/gh/config.yml

# thefuck
!.config/thefuck
.config/thefuck/*
!.config/thefuck/settings.py

# Global git ignore
!.config/git
.config/git/*
!.config/git/ignore

# JetBrains keymaps (canonical copy)
!.config/jetbrains-keymaps
!.config/jetbrains-keymaps/*

# SSH (config only, NOT keys)
!.ssh
.ssh/*
!.ssh/config

# macOS input sources
!Library
Library/*
!Library/Preferences
Library/Preferences/*
!Library/Preferences/com.apple.HIToolbox.plist

# Always ignore
.DS_Store
